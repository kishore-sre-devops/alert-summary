<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/rootLayout"
    android:background="#D50000"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:text="🚨 CRITICAL ALERT"
        android:textColor="@android:color/white"
        android:textSize="28sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/detailsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTitle"
        android:layout_marginTop="30dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#33000000"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SITE / SERVER IP"
            android:textColor="#FFCDD2"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSiteValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="192.168.1.1"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="METRIC NAME"
            android:textColor="#FFCDD2"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMetricValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hardware CPU"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HARDWARE / DETAILS"
            android:textColor="#FFCDD2"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHardwareValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CPU-0 (Core 1)"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THRESHOLD / VALUE"
            android:textColor="#FFCDD2"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvThresholdValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="95% > 90%"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/detailsContainer"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="Message details will appear here..."
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:alpha="0.9" />

    <Button
        android:id="@+id/btnAcknowledge"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#D50000"
        android:text="GO TO APP &amp; ACK"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btnViewDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/btnAcknowledge"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:text="[ VIEW FULL DETAILS ]"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true" />

</RelativeLayout>
