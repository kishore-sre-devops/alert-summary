#!/bin/bash
# Git pre-commit hook to ensure agent version is updated when code changes
# Install with: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Check if agent/go/main.go was modified
if git diff --cached --name-only | grep -q "agent/go/main.go"; then
    AGENT_MODIFIED=1
else
    AGENT_MODIFIED=0
fi

# Get the current version in the code
CURRENT_VERSION=$(grep -oP 'const AgentVersion = "\K[^"]+' agent/go/main.go 2>/dev/null)

# Get the version in the last commit
if [ -z "$CURRENT_VERSION" ]; then
    echo "Could not determine agent version"
    exit 0
fi

# Check if agent/go/ files are staged (modified)
AGENT_FILES_CHANGED=$(git diff --cached --name-only | grep "^agent/go/" | grep -v "VERSION_UPDATE_GUIDE.md" | wc -l)

if [ "$AGENT_FILES_CHANGED" -gt 0 ]; then
    # Agent code has been modified
    # Check if AgentVersion was also modified
    if git diff --cached -- agent/go/main.go | grep -q "const AgentVersion"; then
        # Version was updated - good!
        echo -e "${GREEN}✓ Agent code modified and version updated to ${CURRENT_VERSION}${NC}"
        exit 0
    else
        # Agent code modified but version NOT updated - warn user
        echo ""
        echo -e "${RED}⚠️  WARNING: Agent code was modified but version number was NOT updated!${NC}"
        echo ""
        echo "Modified agent files:"
        git diff --cached --name-only | grep "^agent/go/" | sed 's/^/   /'
        echo ""
        echo "Current version: ${CURRENT_VERSION}"
        echo ""
        echo -e "${YELLOW}📝 You must update the version in: agent/go/main.go${NC}"
        echo ""
        echo "Steps to fix:"
        echo "1. Edit agent/go/main.go"
        echo "2. Find: const AgentVersion = \"${CURRENT_VERSION}\""
        echo "3. Update version number (e.g., to 1.0.3 for a patch)"
        echo "4. Add changelog comment explaining what changed"
        echo "5. Stage changes: git add agent/go/main.go"
        echo "6. Try commit again"
        echo ""
        echo -e "${YELLOW}Or bypass this check with: git commit --no-verify${NC}"
        echo ""
        exit 1
    fi
fi

exit 0
